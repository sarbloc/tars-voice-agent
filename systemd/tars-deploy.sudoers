# Install to /etc/sudoers.d/tars-deploy with mode 0440.
# Allows sukh to restart and inspect the tars services without a password.
sukh ALL=(root) NOPASSWD: /usr/bin/systemctl restart tars-voice-agent.service
sukh ALL=(root) NOPASSWD: /usr/bin/systemctl restart tars-token-server.service
sukh ALL=(root) NOPASSWD: /usr/bin/systemctl restart tars-caddy.service
sukh ALL=(root) NOPASSWD: /usr/bin/systemctl status tars-voice-agent.service
sukh ALL=(root) NOPASSWD: /usr/bin/systemctl status tars-token-server.service
sukh ALL=(root) NOPASSWD: /usr/bin/systemctl status tars-caddy.service
sukh ALL=(root) NOPASSWD: /usr/bin/journalctl -u tars-voice-agent.service *
sukh ALL=(root) NOPASSWD: /usr/bin/journalctl -u tars-token-server.service *
sukh ALL=(root) NOPASSWD: /usr/bin/journalctl -u tars-caddy.service *
