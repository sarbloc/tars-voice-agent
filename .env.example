# === LiveKit ===
# Local LiveKit server (run `livekit-server --dev` for defaults)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_IDENTITY=user

# === LLM Backend ===
# Any OpenAI-compatible Chat Completions API.
# Examples: OpenAI, Ollama, LiteLLM, vLLM, a custom gateway, etc.
OPENCLAW_URL=http://127.0.0.1:11434/v1
OPENCLAW_GATEWAY_TOKEN=your-api-key-here

# If your LLM backend uses a different model name, set it here.
# The agent sends requests to the Chat Completions endpoint with this model.
# LLM_MODEL=openclaw:cooper

# === Speech-to-Text (Whisper) ===
# Any OpenAI-compatible STT server. Recommended: Speaches (faster-whisper).
# https://github.com/speaches-ai/speaches
WHISPER_BASE_URL=http://localhost:8001/v1

# === Text-to-Speech (Kokoro) ===
# Any OpenAI-compatible TTS server. Recommended: Kokoro-FastAPI.
# https://github.com/remsky/Kokoro-FastAPI
KOKORO_BASE_URL=http://localhost:8002/v1
TARS_VOICE=am_onyx

# === Personalization ===
SESSION_ID=voice-user
# Pipe-separated list of greetings — one is chosen at random per connection.
# Falls back to GREETING_MESSAGE for backwards compatibility.
GREETING_MESSAGES=Hey, what's going on?|Hey, what's up?|Yeah, I'm here. What's up?
# Vocabulary hint for STT — mention names, jargon, or product names
# that the speech model might otherwise mishear.
STT_VOCABULARY_HINT=TARS is an AI voice assistant.

# === VAD + Interruption Tuning ===
# Higher values reject distant/cross-room voices and brief background noise
# at the cost of slightly slower turn-taking. All values are seconds except
# the activation threshold (0.0–1.0 Silero confidence).
#
# Silero probability above this counts as speech. Raise to reject quiet/distant audio.
VAD_ACTIVATION_THRESHOLD=0.7
# Minimum speech length to start a speech chunk. Raise to reject pops/short overhearing.
VAD_MIN_SPEECH_DURATION=0.2
# Silence after speech before the chunk ends. Raise if the agent cuts you off mid-sentence.
VAD_MIN_SILENCE_DURATION=0.55
# Minimum speech duration (s) required to actually interrupt TARS while it's speaking.
INTERRUPTION_MIN_DURATION=0.8
# Extra wait after the LiveKit turn detector decides you're finished. Raise to give
# yourself more pause-room when the model is confident you're done.
TURN_ENDPOINTING_MIN_DELAY=0.4

# === TTS Tuning ===
# Kokoro playback speed multiplier. 1.0 = native, <1.0 = slower and more
# natural, >1.0 = faster. 0.92 is a good starting point for conversational
# pacing; drop to 0.88 for a noticeably relaxed cadence.
KOKORO_SPEED=0.92
